{
  "name": "paper-trail",
  "description": "A Paper Trail that integrates with Stripe in order to send invoices.",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && npx @biomejs/biome check --write ./src",
    "build": "tsc && vite build",
    "dev": "vite dev",
    "test": "vitest run",
    "seed": "wrangler d1 execute paper-trail-db --local --file=api/db/seed.sql",
    "seed:remote": "wrangler d1 execute paper-trail-db --remote --file=api/db/seed.sql",
    "deploy": "pnpm run build && wrangler deploy",
    "enc:key": "node ./scripts/generate-encryption-key.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.12",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanitize-filename": "^1.6.4",
    "stripe": "^22.0.1",
    "summit-kit": "^3.5.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@cloudflare/vite-plugin": "^1.31.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  }
}
