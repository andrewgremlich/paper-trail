{
	"name": "paper-trail",
	"description": "A Paper Trail that integrates with Stripe in order to send invoices.",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit && npx @biomejs/biome check --write ./src ./workers",
		"dev": "vite",
		"dev:api": "cd workers && npm run dev",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"test": "vitest run"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-table": "^8.21.3",
		"class-variance-authority": "^0.7.1",
		"classnames": "^2.5.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"lucide-react": "^0.562.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sanitize-filename": "^1.6.3",
		"summit-kit": "^3.2.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	}
}
